# SmartBot Cache v4.0 — Environment Variables
# ใส่อย่างน้อย 1 API Key ระบบถึงทำงานได้

# ── API Keys ─────────────────────────────────────────────
# Gemini (ฟรี 1,500/วัน) ← แนะนำเริ่มต้น
GEMINI_API_KEY=AIza...

# DeepSeek ($0.28/M tokens) ← optional
DEEPSEEK_API_KEY=sk-...

# Claude Sonnet ($3/M tokens) ← optional
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────
PORT=8080

# ── Cache ─────────────────────────────────────────────────
CACHE_TTL_MS=3600000      # 1 ชั่วโมง
MAX_CACHE=10000            # จำนวน entry สูงสุด
SEM_THRESH=0.72            # Semantic similarity threshold

# ── Security ──────────────────────────────────────────────
MAX_BODY_KB=32             # ขนาด request body สูงสุด
RATE_LIMIT=300             # requests สูงสุดต่อ window
RATE_WINDOW=60000          # window ขนาด (ms)

# ── Performance ───────────────────────────────────────────
MODEL_TIMEOUT=15000        # timeout ต่อ model (ms)
LOG_LEVEL=info             # info | debug | error
